# ─── Web App Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in all values before running

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/platform_web?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Microservice URLs (internal / Docker network) ─────────────────────────────
KYC_SERVICE_URL="http://kyc-service:4003"
AUTH_SERVICE_URL="http://auth-service:4001"
USER_SERVICE_URL="http://user-service:4002"
TENANT_SERVICE_URL="http://tenant-service:4004"
FORM_SERVICE_URL="http://form-service:4005"
SUBMISSION_SERVICE_URL="http://submission-service:4006"
LICENSE_SERVICE_URL="http://license-service:4007"
NOTIFICATION_SERVICE_URL="http://notification-service:4008"

# ── Public URLs (exposed to browser) ─────────────────────────────────────────
NEXT_PUBLIC_KYC_SERVICE_URL="http://localhost:4003"
NEXT_PUBLIC_API_GATEWAY_URL="http://localhost:4000"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Seed passwords (used only by prisma/seed.ts) ─────────────────────────────
SEED_SUPER_ADMIN_PASSWORD="SuperAdmin@123!"
SEED_ADMIN_PASSWORD="Admin@Acme123!"
